% Tashfeen's symbol macros
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hwsymb}[2023/01/01 hwsymb]

\PassOptionsToPackage{rgb}{xcolor}
\RequirePackage{amsmath, amssymb, amsthm, amscd, graphicx, cancel, xcolor, environ, pgfkeys, expl3, etoolbox, mathtools, tabto, xparse}
\def\currentquestion{}

% new and renewed commands
\ExplSyntaxOn
\NewDocumentCommand \minidots {}{
  \hbox_to_wd:nn {0.05\headwidth}{
    \tikz{\draw[loosely~dotted,opacity=0.9] (0,0)--({0.05*\headwidth},0);}%
  }
  \skip_vertical:n{-0.4pt}
}

\NewDocumentCommand \widedots{}{
  \skip_vertical:n {-0.5\baselineskip}
  \par
  \hbox_to_wd:nn {\linewidth}
  {
    \tikz{\draw[loosely~dashdotted,opacity=0.3] (0,0)--({\linewidth},0);}%
  }
}

\NewDocumentCommand \marginsymbol{m}{
  \hbox_to_wd:nn { 0pt }{ 
    \skip_horizontal:n { -0.35\leftmargin }
    \hss#1 
    \skip_horizontal:n { 0.35\leftmargin }
  }
  \ignorespaces
}

\NewDocumentCommand \question {O{0}mm}{
  \goodbreak
  \par\noindent
  \marginsymbol{$\to$}
  \textbf{\expandafter\ifx\currtitle\undefined\else{\currtitle.}\fi#2.}
  \def\currentquestion{#2}~
  #3%
  \widedots{}
  \int_compare:nNnT {#1} < {1} {
    \clist_push:Nn \l_hw_questions_clist {#2}
  }
  \int_incr:N \l_hw_int_total_questions
}

\NewDocumentCommand \qprt { mm } {
  \par\noindent
  \int_compare:nNnTF {\col@number} > {1} {
    #1. \quad #2
  } {
    \marginsymbol{#1.}{#2}
  }
}

\NewDocumentCommand{\cvec}{m} {
  \bmqty{\clist_use:nn {#1} {\\}} 
}
\NewDocumentCommand{\rcvec}{m} {
  \trans{\brk{\clist_use:nn {#1} {,}}}
}
\ExplSyntaxOff

